def main [
  --list (-l)     # Only print monitor names
  --disabled (-d) # Include disabled monitors
  --edid (-e)     # Include edid info
]: nothing -> string {

 let entries = try {
     ls /sys/class/drm | where name =~ card\d+-
   } catch (wrap-err-msg "Failed to query sys drm files")
  log info $"entries: \n($entries)"

  # Filter based on `enabled`
  let entries = if ($disabled) {
  } else { $entries }

  # Print monitor names and exit
  if ($list) {
    return 
  }

  # Print json data
  let monitor_info = (
    $entries | each {|it|
      let info = get-monitor-info $it.name
      if (not $edid) { $info } else {
        let edid_info = get-edid-info $"($it.name)/edid"
        info | merge $edid_info
      }
    }
  )
  return {
    monitors: $monitor_info
    lid: { open: (get-lid-state) }
  } | to json
