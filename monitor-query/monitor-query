#!/usr/bin/env -S nu --stdin

use std/log

# Lid detection logic
def get-lid-state []: nothing -> bool {
  let lid_file = (glob /proc/acpi/button/lid/*/state | first)
  log info $"lidfile: ($lid_file)"
  if ($lid_file | is-empty) { 
    return true 
  }
  log info $"lidfile is not empty"
  try {
    let lid_file_content = open $lid_file
    log info $"lidfile: ''($lid_file_content)''"
    return ($lid_file_content =~ open)
  } catch {|e|
    error make {
      msg: "Failed to open lid status file"
      raw: $e
    }
  }
}

