# nu-lint-ignore: missing_output_type
def get-monitor-field [path:path, field:string]: nothing -> any {
  if ($"($path)/($field)" | path exists) {
    try {
      open $"($path)/($field)" | str trim
    } catch (wrap-err-msg $"Failed to get monitor value: ($field)")
  }
  return null
}

def get-monitor-info [path:path]: nothing -> record {
  let modes = (
    get-monitor-field $path modes
    | if ($in == null) { [] }
      else { $in | lines | str trim }
  )
  {
    name: ($path | path basename)
    interface: (($path | path basename) | str replace --regex card\d+- '')
    status:  (get-monitor-field $path status)
    enabled: (get-monitor-field $path enabled)
    modes: $modes
  }
}
